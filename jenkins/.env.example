# Copy to jenkins/.env (do not commit jenkins/.env)
#
# Mac:
#   COMPOSE_DIR=/Users/hsuan/Desktop/ems-backend
# EC2:
#   COMPOSE_DIR=/home/ec2-user/ems-backend

EC2_HOST=18.225.218.150
COMPOSE_DIR=/Users/hsuan/Desktop/ems-backend
SSH_KEY_PATH=/Users/hsuan/.ssh/ems-jenkins-key.pem

# SonarQube (after docker compose up -d):
#   UI: http://localhost:9000
#   Jenkins credential ID: sonar-token
#   Jenkins SonarQube server name: sonarqube

# Google OAuth2 + JWT (required on EC2 for secured APIs):
# GOOGLE_CLIENT_ID=your-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-secret
# JWT_SECRET=use-a-long-random-string-at-least-32-chars
# Google redirect URI: http://<EC2_IP>:8088/login/oauth2/code/google
